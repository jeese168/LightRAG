      "isDeleted": false,
      "boundElements": null,
      "updated": 1770106197998,
      "link": null,
      "locked": false,
      "text": "获锁 → 获文档 → 一致性检查 → 分块 → 提取实体/关系 → 并发合并到图 → 更\n新状态 → 检查是否有新文档 → 重复",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "获锁 → 获文档 → 一致性检查 → 分块 → 提取实体/关系 → 并发合并到图 → 更新状态 → 检查是否有新文档 → 重复",
      "autoResize": false,
      "lineHeight": 1.25
    },
